<!-- lessons/union_sqli/views/union_result.ejs -->
<div class="flex min-h-screen bg-gray-50 p-4">
  <!-- 왼쪽: 결과 -->
  <main class="w-2/3 pr-4">
    <div class="bg-white shadow-md rounded-lg p-8 space-y-6">
      <h2 class="text-2xl font-bold">조회 결과</h2>

      <% if (rows.length === 0) { %>
        <div class="p-4 bg-red-100 text-red-800 rounded">
          조회된 항목이 없습니다.
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full bg-white">
            <thead>
              <tr class="bg-gray-200 text-gray-700">
                <th class="px-4 py-2 text-left">ID</th>
                <th class="px-4 py-2 text-left"><%= Object.keys(rows[0])[1] %></th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach(r => { %>
                <tr class="border-b">
                  <td class="px-4 py-2"><%= r.id %></td>
                  <td class="px-4 py-2"><%= Object.values(r)[1] %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <div class="text-right">
        <a
          href="/lesson/union_sqli"
          class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 transition"
        >다시 조회</a>
         <a
         href="/lesson/union_sqli_secure"
         class="ml-4 px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition"
       >
         보안된 버전 보기
       </a>
      </div>
    </div>
  </main>

  <!-- 오른쪽: 실습용 SQL 템플릿 -->
  <aside class="w-1/3 pl-4 sticky top-4">
    <div class="bg-white shadow-md rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-2">실습용 SQL 템플릿</h3>
      <pre class="whitespace-pre-wrap break-words bg-gray-100 p-4 rounded text-sm">
SELECT id, title
FROM articles
WHERE id = '&lt;id&gt;';
      </pre>
      <p class="mt-2 text-gray-600 text-xs">‘&lt;id&gt;’ 자리에 입력값이 들어갑니다.</p>
    </div>
  </aside>
</div>