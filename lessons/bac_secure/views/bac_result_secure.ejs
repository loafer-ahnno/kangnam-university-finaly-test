<!-- lessons/bac_secure/views/bac_result_secure.ejs -->
<div class="flex min-h-screen bg-gray-50 p-4">
  <!-- ─────────────────────────────────────────────────────────────── 
       왼쪽: 파일 조회 결과
    ─────────────────────────────────────────────────────────────── -->
  <main class="w-2/3 pr-4">
    <div class="bg-white rounded-lg shadow-md w-full p-6 space-y-6 mx-auto mt-16">
      <!-- 1. 파일명 헤더 -->
      <h2 class="text-2xl font-semibold text-gray-800">
        🔒 <span class="capitalize"><%= file %></span> 조회 결과
      </h2>

      <!-- 2. 에러 또는 파일 내용 -->
      <% if (error) { %>
        <div class="p-4 bg-red-100 text-red-800 rounded text-sm">
          <%= error %>
        </div>
      <% } else { %>
        <pre class="bg-gray-100 rounded p-4 text-sm text-gray-700 whitespace-pre-wrap overflow-auto">
<%= content %>
        </pre>
      <% } %>

      <!-- 3. 버튼 그룹 -->
      <div class="flex justify-between">
        <!-- 왼쪽 버튼들 -->
        <div class="space-x-2">
          <a
            href="/lesson/bac_secure"
            class="px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600 transition"
          >
            다시 조회
          </a>
          <a
            href="/lesson/bac"
            class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition"
          >
            취약 버전으로 돌아가기
          </a>
        </div>
        <!-- 홈으로 버튼 -->
        <div>
          <a
            href="/"
            class="px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300 transition"
          >
            홈으로
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- ─────────────────────────────────────────────────────────────── 
       오른쪽: Broken Access Control 방어법 요약
    ─────────────────────────────────────────────────────────────── -->
  <aside class="w-1/3 pl-4">
    <div class="bg-white rounded-lg shadow-md p-6 space-y-6 mx-auto mt-16">
      <h3 class="text-lg font-semibold mb-2">🔐 Broken Access Control 방어 기법</h3>

      <!-- 1) 최소 권한 원칙 -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">1. 최소 권한 원칙 (Least Privilege)</h4>
        <p class="text-gray-600 text-sm">
          • 애플리케이션 및 사용자 계정에 꼭 필요한 권한만 부여합니다.<br/>
          • 예를 들어, 조회 전용 페이지 접근 권한만 필요하면 쓰기 권한은 제거하여<br/>
            공격자가 권한을 넘어선 조작을 하지 못하게 합니다.
        </p>
      </div>

      <!-- 2) 서버 측 권한 검증 -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">2. 서버 측 권한 검증 (Authorization)</h4>
        <p class="text-gray-600 text-sm">
          • 모든 민감한 리소스 요청 시, 세션 또는 토큰을 기반으로<br/>
            사용자가 해당 리소스를 조회/수정할 권한이 있는지 서버에서 재검증합니다.<br/>
          • 클라이언트 사이드 검사만 의존하지 않고, 서버에서 강제 검사를 수행해야 합니다.
        </p>
      </div>

      <!-- 3) 튜닝된 라우트 및 엔드포인트 구조 -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">3. 튜닝된 라우트 및 엔드포인트 구조</h4>
        <p class="text-gray-600 text-sm">
          • URL 패턴이나 파라미터를 통해 사용자가 임의로 다른 리소스에 접근하지 못하도록<br/>
            인증 및 권한 검증을 강화합니다.<br/>
          • 예를 들어, <code>/users/:userId/profile</code> 요청 시, 로그인한 사용자의 ID와 <span class="font-mono">:userId</span> 가 일치하는지 확인합니다.
        </p>
      </div>

      <!-- 요약 안내 -->
      <div class="pt-4 border-t border-gray-200">
        <p class="text-xs text-gray-500">
          ※ 위 세 가지 기법을 결합하여 적용하면, Broken Access Control 취약점을 효과적으로 방어할 수 있습니다.
        </p>
      </div>
    </div>
  </aside>
</div>