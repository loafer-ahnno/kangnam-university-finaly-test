<!-- lessons/open_redirect/views/open_redirect_form.ejs -->
<div class="flex items-center justify-center min-h-screen bg-gray-50 p-4">
  <div class="bg-white shadow-md rounded-lg p-8 w-full max-w-md">
    <h2 class="text-2xl font-bold mb-6 text-center">Open Redirect 연습</h2>
    <p class="text-gray-600 mb-6">무분별한 리다이렉트 탐색</p>
    <form action="/lesson/open_redirect/go" method="get" class="space-y-4">
      <div>
        <label for="next" class="block text-gray-700 mb-2">리다이렉트할 URL</label>
        <input
          id="next"
          name="next"
          type="url"
          placeholder="https://google.com 또는 http://naver.com"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring focus:border-blue-300"
        />
      </div>
      <button
        type="submit"
        class="w-full py-2 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 transition"
      >
        이동
      </button>
    </form>

    <!-- 힌트 토글 및 보안 버전 보기 버튼 -->
    <div class="mt-6 text-center space-x-2">
      <button
        id="hint-btn"
        class="px-4 py-2 bg-yellow-400 text-yellow-900 rounded hover:bg-yellow-500 transition"
      >
        힌트 보기
      </button>
      <a
        href="/lesson/open_redirect_secure"
        class="px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600 transition"
      >
        보안 버전 보기
      </a>
    </div>

    <!-- 힌트 박스 -->
    <div
      id="hint-box"
      class="hidden mt-4 p-6 bg-yellow-100 text-yellow-800 rounded-lg space-y-4 text-sm"
    >
      <div class="flex items-start space-x-2">
        <span class="mt-1 text-yellow-600">▶</span>
        <p>
          이 애플리케이션은 사용자가 입력한 <code class="bg-yellow-200 px-1 rounded">next</code> 값을
          그대로 <code class="bg-yellow-200 px-1 rounded">res.redirect()</code>에 전달합니다.
        </p>
      </div>
      <div>
        <p class="font-semibold">힌트:</p>
        <ul class="list-disc list-inside space-y-1">
          <li>
            전체 URL(프로토콜 포함)을 <code class="bg-yellow-200 px-1 rounded">next</code>에
            입력해 보세요. 예: <code class="bg-yellow-200 px-1 rounded">http://evil.com</code>
          </li>
          <li>
            상대경로가 아닌 완전한 도메인을 지정해야 외부 사이트로 이동합니다.
          </li>
          <li>
            브라우저 주소창이 바뀌는지, 네트워크 탭에서 리다이렉트 응답을 확인해 보세요.
          </li>
        </ul>
      </div>
    </div>

    <p class="mt-6 text-center">
      <a href="/" class="text-gray-600 hover:text-gray-800 underline">← 홈으로</a>
    </p>
  </div>
</div>

<script>
  document.getElementById('hint-btn').addEventListener('click', function() {
    const box = document.getElementById('hint-box');
    if (box.classList.contains('hidden')) {
      box.classList.remove('hidden');
      this.textContent = '힌트 숨기기';
    } else {
      box.classList.add('hidden');
      this.textContent = '힌트 보기';
    }
  });
</script>