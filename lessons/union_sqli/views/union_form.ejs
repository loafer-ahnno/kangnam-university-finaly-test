<!-- lessons/union_sqli/views/union_form.ejs -->
<div class="flex min-h-screen bg-gray-50 p-4">
  <!-- 왼쪽: 폼 + 힌트 -->
  <main class="w-2/3 pr-4">
    <div class="bg-white shadow-md rounded-lg p-8 space-y-6">
     <h2 class="text-2xl font-bold">SQL Injection 연습</h2>
     <p class="text-gray-600 mb-6">UNION SELECT 를 이용해 추가 데이터 유출 연습</p>
      <form action="/lesson/union_sqli/query" method="get" class="space-y-4">
        <div>
          <label for="id" class="block text-gray-700 mb-1">Article ID</label>
          <input
            id="id"
            name="id"
            type="text"
            placeholder="1 또는 1 UNION SELECT NULL, password FROM users--"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring focus:border-blue-300"
          />
        </div>
        <button
          type="submit"
          class="w-full py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition"
        >조회</button>
      </form>

      <div class="text-center">
        <button
          id="hint-btn"
          class="px-4 py-2 bg-yellow-400 text-yellow-900 rounded hover:bg-yellow-500 transition"
        >힌트 보기</button>
      </div>
      <div
        id="hint-box"
        class="hidden p-4 bg-yellow-100 text-yellow-800 rounded text-sm space-y-2"
      >
        <p>▶ 쿼리는 <code class="bg-yellow-200 px-1 rounded">&lt;id&gt;</code> 자리에 입력을 그대로 삽입합니다.</p>
        <p>▶ <code class="bg-yellow-200 px-1 rounded">UNION SELECT</code> 로 두 번째 테이블(users)의 데이터를 합칠 수 있습니다.</p>
        <p>▶ 컬럼 수를 맞추기 위해 <code class="bg-yellow-200 px-1 rounded">NULL</code> 을 쓰고, 뒤는 <code class="bg-yellow-200 px-1 rounded">--</code> 로 주석 처리하세요.</p>
      </div>
    </div>
  </main>

  <!-- 오른쪽: 실습용 SQL 템플릿 -->
  <aside class="w-1/3 pl-4 sticky top-4">
    <div class="bg-white shadow-md rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-2">실습용 SQL 템플릿</h3>
      <pre class="whitespace-pre-wrap break-words bg-gray-100 p-4 rounded text-sm">
SELECT id, title
FROM articles
WHERE id = '&lt;id&gt;';
      </pre>
      <p class="mt-2 text-gray-600 text-xs">‘&lt;id&gt;’ 자리에 입력값이 들어갑니다.</p>
    </div>
  </aside>
</div>

<script>
  document.getElementById('hint-btn').addEventListener('click', function() {
    const box = document.getElementById('hint-box');
    if (box.classList.contains('hidden')) {
      box.classList.remove('hidden');
      this.textContent = '힌트 숨기기';
    } else {
      box.classList.add('hidden');
      this.textContent = '힌트 보기';
    }
  });
</script>