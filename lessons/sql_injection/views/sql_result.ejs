<div class="flex min-h-screen bg-gray-50 p-4">
  <!-- 왼쪽: 결과 + 힌트(원하면) -->
  <main class="w-2/3 pr-4">
    <div class="bg-white shadow-md rounded-lg p-8">
     <h2 class="text-2xl font-bold">조회 결과</h2>
     <p class="text-gray-600 mb-6">입력된 조건으로 조회된 사용자 레코드를 확인하세요</p>

      <% if (rows.length === 0) { %>
        <div class="p-4 bg-red-100 text-red-800 rounded mb-4">
          조회된 사용자 없음
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full bg-white">
            <thead>
              <tr class="bg-gray-200 text-gray-700">
                <th class="px-4 py-2 text-left">ID</th>
                <th class="px-4 py-2 text-left">Username</th>
                <th class="px-4 py-2 text-left">Password</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach(r => { %>
                <tr class="border-b">
                  <td class="px-4 py-2"><%= r.id %></td>
                  <td class="px-4 py-2"><%= r.username %></td>
                  <td class="px-4 py-2"><%= r.password %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <div class="mt-6 flex justify-between">
        <a
          href="/lesson/sql_injection"
          class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 transition"
        >
          다시 검색
        </a>
               <!-- 보안된 버전 보기 버튼 -->
       <a
         href="/lesson/sql_secure"
         class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition"
       >
         보안된 버전 보기
       </a>
      </div>
    </div>
  </main>

  <!-- 오른쪽: SQL 구문 -->
  <aside class="w-1/3 pl-4 sticky top-4">
    <div class="bg-white shadow-md rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-2">실습용 SQL 구문</h3>
      <pre class="whitespace-pre-wrap break-words bg-gray-100 p-4 rounded text-sm">
SELECT id, username, password
FROM users
WHERE username = '&lt;username&gt;';
      </pre>
      <p class="mt-2 text-gray-600 text-xs">
        &lt;username&gt; 에서 사용자 입력값을 바꿔보세요.
      </p>
    </div>
  </aside>
</div>