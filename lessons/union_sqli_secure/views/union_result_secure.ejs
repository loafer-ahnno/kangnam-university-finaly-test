<!-- lessons/union_sqli_secure/views/union_result_secure.ejs -->
<div class="flex min-h-screen bg-gray-50 p-4">

  <!-- 왼쪽: 보안된 버전 결과 테이블 -->
  <main class="w-2/3 pr-4">
    <div class="bg-white shadow-md rounded-lg p-8 space-y-6">

      <!-- 1) 헤더 -->
      <h2 class="text-2xl font-bold">
        Union-based SQLi 조회 결과 (방어 모드)
      </h2>
      <p class="text-gray-600">
        입력된 ID: <code><%= id %></code>,
        컬럼 수: <code><%= cols %></code>
      </p>

      <!-- 2) 에러가 있으면 에러 메시지 출력 -->
      <% if (error) { %>
        <div class="p-4 bg-red-100 text-red-800 rounded">
          ❌ <%= error %>
        </div>

      <!-- 3) 에러 없고 rows가 있으면 조회 결과 테이블 출력 -->
      <% } else if (rows.length) { %>
        <div class="overflow-auto">
          <table class="w-full table-auto border-collapse">
            <thead>
              <tr class="bg-gray-100">
                <th class="px-4 py-2">ID</th>
                <th class="px-4 py-2">Title</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach(r => { %>
                <tr class="border-t">
                  <td class="px-4 py-2"><%= r.id %></td>
                  <td class="px-4 py-2"><%= r.title %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

      <!-- 4) rows가 비어 있으면 조회된 결과 없음 메시지 출력 -->
      <% } else { %>
        <div class="p-4 bg-yellow-100 text-yellow-800 rounded">
          ⚠️ ID에 해당하는 항목이 없거나, 잘못된 요청입니다.
        </div>
      <% } %>

      <!-- 5) 버튼 그룹 -->
      <div class="flex justify-between mt-6">
        <a
          href="/lesson/union_sqli_secure"
          class="px-4 py-2 bg-green-500 text-white rounded-md hover:bg-green-600 transition"
        >
          다시 조회
        </a>
        <a
          href="/lesson/union_sqli"
          class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 transition"
        >
          취약 버전으로 돌아가기
        </a>
      </div>
    </div>
  </main>

  <!-- 오른쪽: 방어 기법 요약 -->
  <aside class="w-1/3 pl-4">
    <div class="bg-white shadow-md rounded-lg p-6 space-y-6">
      <h3 class="text-lg font-semibold mb-2">🔐 Union-based SQLi 방어 요약</h3>

      <!-- 1) Prepared Statement -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">1. Prepared Statement</h4>
        <p class="text-gray-600 text-sm">
          • SQL 쿼리 안에 직접 입력값을 결합하지 않고 <code>?</code> 플레이스홀더를 사용합니다.<br>
            • 이렇게 하면 사용자가 어떤 값을 넣어도 쿼리 구조가 변경되지 않기 때문에 안전합니다.
        </p>
      </div>

      <!-- 2) 입력값 검증 (Validation) -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">2. 입력값 검증</h4>
        <p class="text-gray-600 text-sm">
          • ID와 컬럼 수는 숫자만 허용(<code>/^\d+$/</code>)하도록 검사합니다.<br>
            • 숫자가 아닌 값이나 범위를 벗어난 값은 미리 차단하여 페이로드가 실행되지 않도록 합니다.
        </p>
      </div>

      <!-- 3) ORM / Query Builder -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">3. ORM / Query Builder</h4>
        <p class="text-gray-600 text-sm">
          • Sequelize, TypeORM, Prisma 같은 라이브러리를 사용하면 내부적으로<br>
            Prepared Statement를 자동으로 적용하므로 Union 기반 공격을 방지할 수 있습니다.
        </p>
      </div>

      <!-- 요약 안내 -->
      <div class="pt-4 border-t border-gray-200">
        <p class="text-xs text-gray-500">
          ※ 위 세 가지 기법을 모두 적용하면 Union 기반 SQL Injection 공격을 효과적으로 막을 수 있습니다.
        </p>
      </div>
    </div>
  </aside>
</div>