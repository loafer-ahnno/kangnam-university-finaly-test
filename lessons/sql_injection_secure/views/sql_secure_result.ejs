<!-- lessons/sql_injection_secure/views/sql_secure_result.ejs -->
<div class="flex min-h-screen bg-gray-50 p-4">

  <!-- 왼쪽 메인 영역: 결과 테이블 -->
  <main class="w-2/3 pr-4">
    <div class="bg-white shadow-md rounded-lg p-8 space-y-6">
      <h2 class="text-2xl font-bold">조회 결과 (방어 모드)</h2>
      <p class="text-gray-600">입력된 id: <code><%= id %></code></p>

      <% if (rows.length) { %>
        <table class="w-full table-auto border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="px-4 py-2">ID</th>
              <th class="px-4 py-2">Username</th>
              <th class="px-4 py-2">Password</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach(r => { %>
              <tr class="border-t">
                <td class="px-4 py-2"><%= r.id %></td>
                <td class="px-4 py-2"><%= r.username %></td>
                <td class="px-4 py-2"><%= r.password %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="p-4 bg-red-100 text-red-800 rounded">
          ❌ 조회된 결과가 없습니다. 올바른 숫자 ID를 입력하세요.
        </div>
      <% } %>

      <div class="flex justify-between mt-6">
        <a
          href="/lesson/sql_secure"
          class="px-4 py-2 bg-green-500 text-white rounded-md hover:bg-green-600 transition"
        >
          다시 조회
        </a>
        <a
          href="/lesson/sql_injection"
          class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 transition"
        >
          취약 버전으로 돌아가기
        </a>
      </div>
    </div>
  </main>

  <!-- 오른쪽 사이드바: 요약된 방어법 -->
  <aside class="w-1/3 pl-4">
    <div class="bg-white shadow-md rounded-lg p-6 space-y-6">
      <h3 class="text-lg font-semibold mb-2">🔐 주요 방어 기법 요약</h3>

      <!-- 1. Prepared Statement -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">1. Prepared Statement</h4>
        <p class="text-gray-600 text-sm">
          • 쿼리 틀과 입력값을 분리하여, 사용자가 어떤 값을 넣어도 SQL 구조가 변경되지 않습니다.
        </p>
      </div>

      <!-- 2. 입력값 검증 (Validation) -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">2. 입력값 검증</h4>
        <p class="text-gray-600 text-sm">
          • 숫자·문자열 등 형식에 맞는 값만 허용하여, 비정상 입력(예: ' OR 1=1--)을 차단합니다.
        </p>
      </div>

      <!-- 3. ORM / Query Builder -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">3. ORM / Query Builder</h4>
        <p class="text-gray-600 text-sm">
          • Sequelize, TypeORM 등 라이브러리를 사용하면 자동으로 안전한 쿼리를 생성합니다.
        </p>
      </div>
    </div>
  </aside>
</div>