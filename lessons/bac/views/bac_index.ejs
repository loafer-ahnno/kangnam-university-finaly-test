<!-- lessons/bac/views/bac_index.ejs -->
<div class="flex items-center justify-center min-h-screen bg-gray-50 p-4">
  <div class="bg-white shadow-md rounded-lg p-8 w-full max-w-md space-y-6">
    <h2 class="text-2xl font-bold">🔒 Broken Access Control (IDOR) 연습</h2>
    <p class="text-gray-600 mb-6">IDOR 취약점 학습</p>

    <div>
      <p class="mb-2 text-gray-700">공개 파일:</p>
      <a
        href="/lesson/bac/files?file=public.txt"
        class="block px-4 py-2 bg-blue-100 text-blue-800 rounded hover:bg-blue-200 transition"
      >
        public.txt
      </a>
    </div>

    <!-- 학습용 힌트 토글 버튼 -->
    <div class="text-center">
      <button
        id="hint-btn"
        class="px-4 py-2 bg-yellow-400 text-yellow-900 rounded hover:bg-yellow-500 transition"
      >
        힌트 보기
      </button>
    </div>

    <!-- 힌트 박스 (초기 hidden) -->
    <div
      id="hint-box"
      class="hidden p-6 bg-yellow-100 text-yellow-800 rounded-lg space-y-4 text-sm"
    >
      <div class="flex items-start space-x-2">
        <span class="mt-1 text-yellow-600">▶</span>
        <p>
          URL의 <code class="bg-yellow-200 px-1 rounded">file</code> 파라미터 값을
          바꿔보면 서버의 다른 파일에도 접근할 수 있을지도 모릅니다.
        </p>
      </div>
      <div>
        <p class="font-semibold">힌트:</p>
        <ul class="list-disc list-inside space-y-1">
          <li>
            프로젝트의 <code class="bg-yellow-200 px-1 rounded">lessons/bac/data</code>
            폴더를 확인해 어떤 파일들이 있는지 추측해 보세요.
          </li>
          <li>
            파일 이름 뒤에 <code class="bg-yellow-200 px-1 rounded">.txt</code> 확장자를
            붙여서 요청을 시도해 보세요.
          </li>
        </ul>
      </div>
    </div>

    <p class="text-sm text-gray-500">
      ※ 위 <code class="bg-yellow-200 px-1 rounded">file</code> 파라미터를 바꿔서
      비공개 파일 요청을 시도해 보세요!
    </p>

    <p class="text-center">
      <a href="/" class="text-gray-600 hover:text-gray-800 underline">← 홈으로</a>
    </p>
  </div>
</div>

<script>
  document.getElementById('hint-btn').addEventListener('click', function() {
    const box = document.getElementById('hint-box');
    if (box.classList.contains('hidden')) {
      box.classList.remove('hidden');
      this.textContent = '힌트 숨기기';
    } else {
      box.classList.add('hidden');
      this.textContent = '힌트 보기';
    }
  });
</script>