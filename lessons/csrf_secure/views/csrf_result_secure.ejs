<!-- lessons/csrf_secure/views/csrf_secure_result.ejs -->
<div class="flex min-h-screen bg-gray-50 p-4">
  <!-- ─────────────────────────────────────────────────────────────── 
       왼쪽: 이메일 변경 완료 (방어 모드) 결과
    ─────────────────────────────────────────────────────────────── -->
  <main class="w-2/3 pr-4">
    <div class="bg-white shadow-md rounded-lg p-8 w-full max-w-sm space-y-6 mx-auto mt-16">
      <h2 class="text-2xl font-bold text-center">이메일 변경 완료 (방어 모드)</h2>
      <p class="text-gray-600 text-center">
        새 이메일: <strong><%= email %></strong>
      </p>

      <div class="flex justify-between mt-6">
        <a
          href="/lesson/csrf_secure"
          class="px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600 transition"
        >
          다시 변경
        </a>
        <a
          href="/lesson/csrf"
          class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition"
        >
          취약 버전으로 돌아가기
        </a>
      </div>
    </div>
  </main>

  <!-- ─────────────────────────────────────────────────────────────── 
       오른쪽: CSRF 방어 기법 요약
    ─────────────────────────────────────────────────────────────── -->
  <aside class="w-1/3 pl-4">
    <div class="bg-white shadow-md rounded-lg p-6 space-y-6 mt-16">
      <h3 class="text-lg font-semibold mb-2">🔐 CSRF 방어 기법</h3>

      <!-- 1) CSRF 토큰 사용 -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">1. CSRF 토큰 발급 및 검증</h4>
        <p class="text-gray-600 text-sm">
          • 서버에서 난수 형태의 토큰을 생성하여 세션 또는 쿠키에 저장하고,  
            폼 요청 시 해당 토큰을 숨은 필드로 함께 전송합니다.<br/>
          • 서버는 요청 시 전송된 토큰이 세션/쿠키에 저장된 값과 일치하는지 검사하여  
            외부에서 위조된 요청을 차단할 수 있습니다.
        </p>
      </div>

      <!-- 2) SameSite 쿠키 속성 -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">2. SameSite 쿠키 속성 설정</h4>
        <p class="text-gray-600 text-sm">
          • 쿠키의 <code>SameSite</code> 속성을 <code>Strict</code> 또는 <code>Lax</code>로 설정하면  
            제3자 사이트에서 보낸 요청에는 쿠키가 전송되지 않습니다.<br/>
          • 이로 인해 공격자가 만든 외부 폼이나 링크를 통해서는 인증 쿠키를 사용한 요청이  
            서버로 전달되지 않으므로 CSRF 공격을 예방할 수 있습니다.
        </p>
      </div>

      <!-- 3) Referer/Origin 헤더 검증 -->
      <div class="space-y-1">
        <h4 class="font-semibold text-gray-800">3. Referer/Origin 헤더 검증</h4>
        <p class="text-gray-600 text-sm">
          • POST 요청 등 중요 상태 변경 요청이 들어올 때, HTTP의  
            <code>Referer</code> 또는 <code>Origin</code> 헤더가  
            신뢰할 수 있는 도메인(자사 도메인)에서 온 것인지 확인합니다.<br/>
          • 이를 통해 외부에서 위조된 요청인지 판별하여, 해당 도메인이 아니면 차단할 수 있습니다.
        </p>
      </div>

      <!-- 요약 안내 -->
      <div class="pt-4 border-t border-gray-200">
        <p class="text-xs text-gray-500">
          ※ 위 세 가지 기법을 모두 적용하면 CSRF 공격을 효과적으로 방어할 수 있습니다.
        </p>
      </div>
    </div>
  </aside>
</div>