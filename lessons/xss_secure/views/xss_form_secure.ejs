<!-- lessons/xss_secure/views/xss_form_secure.ejs -->
<div class="flex items-center justify-center min-h-screen bg-gray-50 p-4">
  <div class="bg-white shadow-md rounded-lg p-8 w-full max-w-md space-y-6">
    <h2 class="text-2xl font-bold text-center">Reflected XSS 방어 버전</h2>
    <p class="text-gray-600 mb-4">모든 사용자 입력을 HTML 이스케이프 처리합니다.</p>

    <form action="/lesson/xss_secure/reflect" method="get" class="space-y-4">
      <label class="block text-gray-700">
        메시지:
        <input
          name="msg"
          type="text"
          value="<%= msg %>"
          placeholder="<script>alert('XSS')</script>"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring"
        />
      </label>

      <button
        type="submit"
        class="w-full py-2 bg-green-600 text-white rounded hover:bg-green-700 transition"
      >
        렌더
      </button>
    </form>

    <p class="text-sm text-gray-500">
      * EJS의 `<%= %>` 기본 escape 로 스크립트 실행을 완전히 방어합니다.
    </p>

    <p class="mt-4 text-center">
      <a href="/lesson/xss" class="underline text-gray-600 hover:text-gray-800">
        ← 취약 버전으로 돌아가기
      </a>
    </p>
  </div>
</div>