<!-- lessons/blind_boolean/views/blind_boolean_result.ejs -->
<div class="flex min-h-screen bg-gray-50 p-4">
  <main class="w-2/3 pr-4">
    <div class="bg-white shadow-md rounded-lg p-8 space-y-6">
      <h2 class="text-2xl font-bold">조회 결과</h2>
       <p class="text-gray-600 mb-6">입력된 조건으로 결과를 확인하세요.</p>

      <% if (conditionMet) { %>
        <div class="p-4 bg-green-100 text-green-800 rounded">
          🎉 조건이 참입니다! admin 비밀번호의 첫 글자는 '<%= guessedChar %>' 입니다.
        </div>
      <% } else { %>
        <div class="p-4 bg-red-100 text-red-800 rounded">
          ❌ 조건이 거짓입니다. 다른 문자를 시도해 보세요.
        </div>
      <% } %>

      <div class="text-right">
        <a
          href="/lesson/blind_boolean"
          class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 transition"
        >
          다시 조회
        </a>
               <a
         href="/lesson/blind_boolean_secure"
         class="ml-4 px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition"
       >
         보안된 버전 보기
       </a>
      </div>
    </div>
  <!-- 오른쪽 SQL 템플릿 패널은 그대로 두시면 됩니다 -->
</div>
  </main>

  <!-- 오른쪽: 실습용 SQL 템플릿 -->
  <aside class="w-1/3 pl-4 sticky top-4">
    <div class="bg-white shadow-md rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-2">실습용 SQL 템플릿</h3>
      <pre class="whitespace-pre-wrap break-words bg-gray-100 p-4 rounded text-sm">
SELECT *
FROM items
WHERE name = '&lt;name&gt;'
  AND (
    SELECT substr(password,1,1)
      FROM users
     WHERE username='admin'
  ) = '&lt;char&gt;';
      </pre>
      <p class="mt-2 text-gray-600 text-xs">
        ‘&lt;name&gt;’ 자리에 입력값, ‘&lt;char&gt;’ 자리에 비교할 문자(예: s) 를 넣어 보세요.
      </p>
    </div>
  </aside>
</div>